# Local defaults. Copy to .env and fill real values locally or in your deploy platform.
APP_NAME=health-checkin-feishu-bot
ENV=local

# Local development uses SQLite. Production can override with PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/health_checkin
DATABASE_URL=sqlite:///./data/app.db
DEFAULT_SEASON_START=2025-05-11

# OpenAI-compatible model gateway.
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=
LLM_MODEL=glm-4.6v
LLM_PROVIDER_ID=
LLM_TIMEOUT_SECONDS=120

# Feishu app settings. Keep secrets in environment variables, not code.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Optional docker-compose PostgreSQL settings.
POSTGRES_DB=health_checkin
POSTGRES_USER=health_checkin
POSTGRES_PASSWORD=change-me
